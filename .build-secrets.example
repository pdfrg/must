# Last.fm API credentials
# Get yours at: https://www.last.fm/api/account/create
# Then copy this file to .build-secrets and fill in your credentials:
#
#   cp .build-secrets.example .build-secrets
#   source .build-secrets && make build
#
# This embeds the credentials at build time so you don't need to configure
# them in ~/.config/must/config.toml.
#
# Alternatively, pass them directly to make:
#   make build LASTFM_KEY=xxx LASTFM_SECRET=xxx
#
# Or set them via environment variables and run:
#   go build -ldflags "-X github.com/pdfrg/must/internal/api.LastFMAPIKey=$LASTFM_KEY -X github.com/pdfrg/must/internal/api.LastFMSharedSecret=$LASTFM_SECRET"

LASTFM_KEY=your_api_key_here
LASTFM_SECRET=your_shared_secret_here
